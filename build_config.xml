<?xml version="1.0" encoding="UTF-8"?>
<!-- 
    Clone AI - GitHub CI/CD Build & Compression Configuration Spec
    Automation Specification for Executable Compilation
-->
<BuildConfig project="CloneAI" version="1.3.0" os="windows-x64">
    <Source>
        <EntryPoint>app.py</EntryPoint>
        <Modules>
            <Module>main.py</Module>
            <Module>readmail.py</Module>
        </Modules>
        <DependenciesFile>requirements.txt</DependenciesFile>
    </Source>

    <Compilation tool="PyInstaller">
        <Option flag="--noconsole" description="Hide command prompt window" />
        <Option flag="--onefile" description="Bundle into standalone executable" />
        <OutputName>CloneAI.exe</OutputName>
    </Compilation>

    <PackageStructure outputDir="CloneAI_v1.3.0_Windows_x64">
        <Folder name="config" description="Application configuration directory" />
        <Folder name="logs" description="Runtime log storage" />
        <File source="dist/CloneAI.exe" target="CloneAI.exe" />
        <File source="HDSD.txt" target="HDSD.txt" />
        <Compression type="zip" outputName="CloneAI_v1.3.0_Windows_x64.zip" />
    </PackageStructure>
</BuildConfig>
